{
  "name": "sop-bigquery-sync",
  "version": "1.0.0",
  "description": "Cloud Function para sincronizar dados S&OP com BigQuery",
  "main": "index.js",
  "scripts": {
    "start": "functions-framework --target=syncBigQuery",
    "deploy": "gcloud functions deploy syncBigQuery --runtime nodejs18 --trigger-http --allow-unauthenticated",
    "deploy-secure": "gcloud functions deploy syncBigQuery --runtime nodejs18 --trigger-http"
  },
  "dependencies": {
    "@google-cloud/bigquery": "^7.0.0",
    "@google-cloud/functions-framework": "^3.0.0"
  },
  "devDependencies": {},
  "engines": {
    "node": "18.x"
  }
}
